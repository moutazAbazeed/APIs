{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=ReportsDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },

  "ApiSettings": {
    "BaseUrl": "https://api.yourserver.com",
    "ApiKey": "your-secret-api-key-here",
    "RequireApiKey": true,
    "TokenExpiryHours": 24
  },

  "LicenseSettings": {
    "DefaultExpiryDays": 365,
    "AllowMultipleDevices": false,
    "GracePeriodDays": 7
  },

  "RateLimiting": {
    "Enable": true,
    "PerMinute": 60,
    "PerHour": 1000
  },

  "Jwt": {
    "Key": "your-super-secret-jwt-key-min-32-chars!",
    "Issuer": "ReportsApi",
    "Audience": "ReportsClient"
  },

  "AllowedHosts": "*"
}